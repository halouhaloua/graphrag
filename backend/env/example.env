# 开发环境配置
ENV=dev
DEBUG=False

# 应用配置
APP_NAME=ai
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# 数据库连接URL（由上面的变量自动拼接，无需手动配置）
# 如果需要使用SQLite: DATABASE_URL=sqlite+aiosqlite:///./app.db
# 如果需要使用MySQL: DATABASE_URL=mysql+aiomysql://user:password@host:port/dbname

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Redis连接URL（由上面的变量自动拼接，无需手动配置）
# REDIS_URL=redis://:password@host:port/db

# 缓存配置
CACHE_DEFAULT_EXPIRE=300
CACHE_PREFIX=fastapi:dev:

# 文件存储配置
# local/oss/minio/azure
FILE_STORAGE_TYPE=minio

# Minio配置
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_SECURE=False

# OAuth配置
# Gitee OAuth
GITEE_CLIENT_ID=None
GITEE_CLIENT_SECRET=None
GITEE_REDIRECT_URI='https://localhost:5777/oauth/gitee/callback'
# GitHub OAuth
GITHUB_CLIENT_ID=None
GITHUB_CLIENT_SECRET=None
GITHUB_REDIRECT_URI='https://localhost:5777/oauth/github/callback'
# QQ OAuth
QQ_APP_ID=None
QQ_APP_KEY=None
QQ_REDIRECT_URI='https://localhost:5777/oauth/qq/callback'
# Google OAuth
GOOGLE_CLIENT_ID=None
GOOGLE_CLIENT_SECRET=None
GOOGLE_REDIRECT_URI='https://localhost:5777/oauth/google/callback'
# 微信 OAuth
WECHAT_APP_ID=None
WECHAT_APP_SECRET=None
WECHAT_REDIRECT_URI='https://localhost:5777/oauth/wechat/callback'
# Microsoft OAuth
MICROSOFT_CLIENT_ID=None
MICROSOFT_CLIENT_SECRET=None
MICROSOFT_REDIRECT_URI='https://localhost:5777/oauth/microsoft/callback'
# 钉钉 OAuth
DINGTALK_APP_ID=None
DINGTALK_APP_SECRET=None
DINGTALK_REDIRECT_URI='https://localhost:5777/oauth/dingtalk/callback'
# 飞书 OAuth
FEISHU_APP_ID=None
FEISHU_APP_SECRET=None
FEISHU_REDIRECT_URI='https://localhost:5777/oauth/feishu/callback'
